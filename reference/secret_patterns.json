{
  "patterns": [
    {"name": "Anthropic API key",        "regex": "sk-ant-(?:api|admin)[0-9]{2}-[A-Za-z0-9_\\-]{80,}",                   "severity": "critical"},
    {"name": "OpenAI API key",           "regex": "sk-(?:proj-)?[A-Za-z0-9_\\-]{40,}",                                   "severity": "critical"},
    {"name": "GitHub personal token",    "regex": "gh[pousr]_[A-Za-z0-9]{36,}",                                          "severity": "critical"},
    {"name": "GitHub fine-grained token","regex": "github_pat_[A-Za-z0-9_]{82,}",                                        "severity": "critical"},
    {"name": "Vercel token",             "regex": "(?i)vercel[_-]?token[\\s\"':=]+([A-Za-z0-9]{20,})",                   "severity": "critical"},
    {"name": "HubSpot access token",     "regex": "pat-(?:na|eu)[0-9]+-[a-f0-9\\-]{30,}",                                "severity": "critical"},
    {"name": "Notion integration token", "regex": "(?:secret_|ntn_)[A-Za-z0-9]{40,}",                                    "severity": "critical"},
    {"name": "Google OAuth refresh",     "regex": "1//0[a-zA-Z0-9_\\-]{40,}",                                            "severity": "critical"},
    {"name": "Google OAuth access",      "regex": "ya29\\.[A-Za-z0-9_\\-]{40,}",                                         "severity": "high"},
    {"name": "AWS access key",           "regex": "AKIA[0-9A-Z]{16}",                                                     "severity": "critical"},
    {"name": "AWS secret key (likely)",  "regex": "(?i)aws[_-]?secret[_-]?(?:access[_-]?)?key[\\s\"':=]+([A-Za-z0-9/+=]{40})", "severity": "critical"},
    {"name": "Stripe live key",          "regex": "(?:sk|rk)_live_[A-Za-z0-9]{24,}",                                     "severity": "critical"},
    {"name": "Stripe live publishable",  "regex": "pk_live_[A-Za-z0-9]{24,}",                                            "severity": "high"},
    {"name": "Slack bot/user token",     "regex": "xox[baprs]-[A-Za-z0-9\\-]{10,}",                                      "severity": "critical"},
    {"name": "Twilio account SID",       "regex": "AC[a-f0-9]{32}",                                                       "severity": "high"},
    {"name": "SendGrid key",             "regex": "SG\\.[A-Za-z0-9_\\-]{22}\\.[A-Za-z0-9_\\-]{43}",                      "severity": "critical"},
    {"name": "Asana PAT",                "regex": "(?:2/[0-9]{10,}/|0/)[a-f0-9]{32,}",                                   "severity": "critical"},
    {"name": "Fathom API key",           "regex": "(?i)fathom[_-]?api[_-]?key[\\s\"':=]+([A-Za-z0-9_\\-]{20,})",         "severity": "critical"},
    {"name": "JWT (any)",                "regex": "eyJ[A-Za-z0-9_\\-]{10,}\\.eyJ[A-Za-z0-9_\\-]{10,}\\.[A-Za-z0-9_\\-]{10,}", "severity": "medium"},
    {"name": "Private key block",        "regex": "-----BEGIN (?:RSA |EC |OPENSSH |DSA )?PRIVATE KEY-----",              "severity": "critical"},
    {"name": "Generic high-entropy hex", "regex": "(?<![A-Za-z0-9])[a-f0-9]{40,}(?![A-Za-z0-9])",                        "severity": "low"}
  ],
  "filename_blocklist": [
    ".env",
    ".env.local",
    ".env.production",
    ".env.development",
    "credentials.json",
    "service-account.json",
    "id_rsa",
    "id_ed25519",
    ".npmrc",
    ".pypirc"
  ],
  "scan_extensions": [
    ".py", ".js", ".ts", ".tsx", ".jsx", ".mjs", ".cjs",
    ".json", ".yaml", ".yml", ".toml", ".ini", ".env",
    ".sh", ".bash", ".zsh", ".fish",
    ".md", ".txt", ".html", ".xml",
    ".sql", ".rb", ".go", ".rs", ".java", ".kt", ".swift"
  ],
  "skip_dirs": [
    "node_modules", ".next", ".vercel", "dist", "build",
    "__pycache__", ".pytest_cache", ".mypy_cache", ".ruff_cache",
    ".git", ".venv", "venv", "env",
    ".turbo", ".cache", "coverage",
    "system/finances"
  ]
}
