{
  "description": "Canonical deny-list for ~/.claude/settings.json. These override bypassPermissions and force a prompt regardless of allowlist or default mode. Mimir adds any missing entries on auto-fix.",
  "rules": [
    "Bash(rm -rf:*)",
    "Bash(rm -fr:*)",
    "Bash(rm -rf /*)",
    "Bash(rm -rf ~*)",
    "Bash(rm -rf $HOME*)",
    "Bash(sudo rm:*)",
    "Bash(git push --force:*)",
    "Bash(git push -f:*)",
    "Bash(git push --force-with-lease:*)",
    "Bash(git reset --hard:*)",
    "Bash(git clean -fd:*)",
    "Bash(git clean -fdx:*)",
    "Bash(git checkout --:*)",
    "Bash(git restore --source*)",
    "Bash(git branch -D:*)",
    "Bash(git update-ref -d:*)",
    "Bash(gh repo delete:*)",
    "Bash(gh release delete:*)",
    "Bash(vercel rm:*)",
    "Bash(vercel remove:*)",
    "Bash(vercel project rm:*)",
    "Bash(npm publish:*)",
    "Bash(yarn publish:*)",
    "Bash(pnpm publish:*)",
    "Bash(dd:*)",
    "Bash(mkfs:*)",
    "Bash(diskutil eraseDisk:*)",
    "Bash(diskutil erase:*)",
    "Bash(:(){ :|:& };:)",
    "Bash(curl * | sh)",
    "Bash(curl * | bash)",
    "Bash(curl * | zsh)",
    "Bash(wget * | sh)",
    "Bash(wget * | bash)",
    "Bash(eval *)",
    "Bash(exec *)"
  ]
}
